generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id         Int            @id @default(autoincrement())
  name       String
  location   String
  createdAt  DateTime       @default(now())
  categories MenuCategory[]
  orders     Order[]
}

model MenuCategory {
  id        Int        @id @default(autoincrement())
  name      String
  branchId  Int
  branch    Branch     @relation(fields: [branchId], references: [id])
  menuItems MenuItem[]
}

model MenuItem {
  id              Int          @id @default(autoincrement())
  name            String
  price           Float
  available       Boolean      @default(true)
  categoryId      Int
  createdAt       DateTime     @default(now())
  description     String?
  preparationTime Int          @default(10)
  category        MenuCategory @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
}

model Order {
  id          Int         @id @default(autoincrement())
  status      OrderStatus @default(PLACED)
  totalAmount Float
  createdAt   DateTime    @default(now())
  branchId    Int
  tokenNumber Int        
  collectedAt DateTime?
  notes       String?
  readyAt     DateTime?
  startedAt   DateTime?
  branch      Branch      @relation(fields: [branchId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  quantity   Int
  orderId    Int
  menuItemId Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  COLLECTED
}

model DailyTokenCounter {

  id          Int      @id @default(autoincrement())

  counterDate DateTime @unique

  lastToken   Int
}